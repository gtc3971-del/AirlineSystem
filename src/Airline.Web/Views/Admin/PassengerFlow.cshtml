@model IEnumerable<dynamic>
@{ ViewData["Title"] = "Пассажиропоток"; }
<div class="container mt-5">
    <h2>👥 Пассажиропоток (@ViewBag.Start — @ViewBag.End)</h2>
    <form method="get" class="mb-4 row g-3">
        <div class="col-md-4"><label>С даты</label><input name="start" type="date" value="@ViewBag.Start" class="form-control"></div>
        <div class="col-md-4"><label>По дату</label><input name="end" type="date" value="@ViewBag.End" class="form-control"></div>
        <div class="col-md-4 d-flex align-items-end"><button type="submit" class="btn btn-primary w-100">Обновить</button></div>
    </form>
    <table class="table table-striped">
        <thead class="table-dark"><tr><th>Направление</th><th>Продано билетов</th><th>Выручка (₽)</th></tr></thead>
        <tbody>
            @foreach (var r in Model) {
                <tr><td>@r.Route</td><td><strong>@r.Sold</strong></td><td>@r.Revenue.ToString("N0") ₽</td></tr>
            }
        </tbody>
    </table>
    <a asp-action="Reports" class="btn btn-secondary">← К отчётам</a>
</div>