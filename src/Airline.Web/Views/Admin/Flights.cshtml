@model List<Airline.Web.Models.Flight>
@{
    ViewData["Title"] = "Управление рейсами";
}

<div class="container mt-5">
    <h2>✈️ Управление рейсами</h2>
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <a asp-action="CreateFlight" class="btn btn-primary mb-3">+ Добавить рейс</a>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Рейс</th>
                <th>Маршрут</th>
                <th>Вылет</th>
                <th>Прилёт</th>
                <th>Мест</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flight in Model)
            {
                <tr>
                    <td><strong>@flight.FlightNumber</strong></td>
                    <td>@flight.DepartureAirportCode → @flight.ArrivalAirportCode</td>
                    <td>@flight.DepartureTime.ToString("dd.MM HH:mm")</td>
                    <td>@flight.ArrivalTime.ToString("dd.MM HH:mm")</td>
                    <td><span class="badge bg-success">@flight.AvailableSeats</span></td>
                    <td>@flight.Status</td>
                    <td>
                        <a asp-action="EditFlight" asp-route-id="@flight.Id" class="btn btn-sm btn-warning">Изменить</a>
                        <a asp-action="DeleteFlight" asp-route-id="@flight.Id" class="btn btn-sm btn-danger">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>